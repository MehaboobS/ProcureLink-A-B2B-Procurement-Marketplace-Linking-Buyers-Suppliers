generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  phone           String?          @unique
  passwordHash    String
  role            Role
  entityType      EntityType
  isVerified      Boolean          @default(false)
  kycStatus       KycStatus        @default(PENDING)
  tier            Tier             @default(FREE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  buyerProfile    BuyerProfile?
  requirements    Requirement[]
  supplierProfile SupplierProfile?
  bids Bid[]
  

  @@index([email])
  @@index([role])
}

model BuyerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  companyName String?
  location    String?
  aadhaar     String?
  pan         String?
  gst         String?
  cin         String?
  moa         String?
  workOrder   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model SupplierProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  supplierType    SupplierType
  companyName     String
  gst             String
  location        String
  yearEstablished Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  certifications  Certification[]
  products        Product[]
  categories      SupplierCategory[]
  user            User               @relation(fields: [userId], references: [id])
}

model Category {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  createdAt          DateTime           @default(now())
  parentId           String?
  parent             Category?          @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children           Category[]         @relation("CategoryHierarchy")
  requirements       Requirement[]
  supplierCategories SupplierCategory[]

  @@index([parentId])
}

model SupplierCategory {
  id         String          @id @default(uuid())
  supplierId String
  categoryId String
  category   Category        @relation(fields: [categoryId], references: [id])
  supplier   SupplierProfile @relation(fields: [supplierId], references: [id])

  @@unique([supplierId, categoryId])
  @@index([supplierId])
  @@index([categoryId])
}

model Product {
  id         String          @id @default(uuid())
  supplierId String
  name       String
  specs      String
  moq        Int
  leadTime   Int
  supplyArea String
  supplier   SupplierProfile @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

model Certification {
  id          String          @id @default(uuid())
  supplierId  String
  name        String
  documentUrl String?
  supplier    SupplierProfile @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

model Requirement {
  id               String   @id @default(uuid())
  title            String
  description      String
  categoryId       String
  buyerId          String
  quantity         Int
  unit             String
  deliveryLocation String
  deliveryDeadline DateTime
  budgetMin        Float?
  budgetMax        Float?
  budgetHidden     Boolean  @default(false)
  closingDatetime  DateTime
  biddingMode      String
  visibility       String
  status           String   @default("draft")
  specDocumentUrl  String?
  tags             String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  buyer            User     @relation(fields: [buyerId], references: [id])
  category         Category @relation(fields: [categoryId], references: [id])

  // New Relation
  bids             Bid[]

  @@index([categoryId])
  @@index([buyerId])
}
model Bid {

  id              String      @id @default(uuid())

  requirementId   String
  supplierId      String

  quotedPrice     Float
  quantity        Int
  deliveryDays    Int
  remarks         String?

  status          BidStatus   @default(PENDING)

  rejectionReason String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  supplier User @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([requirementId, supplierId])
}

enum Role {
  BUYER
  SUPPLIER
}

enum EntityType {
  INDIVIDUAL
  SMALL_BUSINESS
  COMPANY
}

enum SupplierType {
  MANUFACTURER
  TRADER
  IMPORTER
  DISTRIBUTOR
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Tier {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}


enum BidStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
}